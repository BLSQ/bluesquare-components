{
    "name": "bluesquare-components",
    "version": "2.0.0",
    "description": "reusable UI components for Bluesquare apps",
    "author": "Bluesquare",
    "license": "Apache-2.0",
    "main": "./dist/index.js",
    "files": [
        "dist"
    ],
    "typings": "./dist/types",
    "scripts": {
        "fix-lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --cache --fix",
        "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\"",
        "show-lint-problems": "eslint \"./src/**/*.{js,jsx,ts,tsx}\"",
        "test": "vitest --config vitest.config.ts --project unit --run",
        "test:watch": "vitest --config vitest.config.ts --project unit",
        "test:a11y": "vitest --config vitest.config.ts --project a11y --run",
        "test:integration": "vitest --config vitest.config.ts --project integration --run",
        "test:all": "vitest --config vitest.config.ts --project unit --project a11y --project integration --run",
        "test:coverage": "vitest run --coverage --config vitest.config.ts --project unit",
        "clean": "rm -rf dist",
        "compile": "npm run clean && NODE_ENV=production babel src --out-dir dist --copy-files --no-copy-ignored",
        "serve": "npm run clean && webpack --mode=production ",
        "build-local": "npm run compile && npm pack",
        "build": "webpack"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/BLSQ/bluesquare-components.git"
    },
    "keywords": [],
    "bugs": {
        "url": "https://github.com/BLSQ/bluesquare-components/issues"
    },
    "homepage": "https://github.com/BLSQ/bluesquare-components#readme",
    "devDependencies": {
